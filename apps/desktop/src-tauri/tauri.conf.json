{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DeskCrafter",
  "version": "0.1.0",
  "identifier": "dev.deskcrafter.launcher",
  "build": {
    "beforeDevCommand": "npm run dev:ui -- --host 127.0.0.1 --port 1420",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:ui",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DeskCrafter",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 640,
        "maxWidth": 1800,
        "maxHeight": 1100
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage"],
    "category": "Utility",
    "shortDescription": "Linux launcher suite",
    "longDescription": "Create, validate, repair, and manage Linux application launchers."
  }
}
